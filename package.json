{
  "name": "swaraj",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "build": "pnpm --filter @swaraj/shared-types build && pnpm --filter @swaraj/shared-utils build && pnpm --filter @swaraj/backend build && pnpm --filter @swaraj/admin build",
    "lint": "pnpm --filter @swaraj/backend lint && pnpm --filter @swaraj/admin lint",
    "test": "pnpm --filter @swaraj/backend test && pnpm --filter @swaraj/admin test",
    "dev:backend": "pnpm --filter @swaraj/backend start:dev",
    "dev:admin": "pnpm --filter @swaraj/admin dev",
    "db:migrate": "pnpm --filter @swaraj/backend prisma:migrate",
    "db:seed": "pnpm --filter @swaraj/backend prisma:seed"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
